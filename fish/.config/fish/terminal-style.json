{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "transient_prompt": {
    "template": "❯ ",
    "foreground": "#c0caf5",
    "foreground_templates": [
      "{{ if gt .Code 0 }}#f7768e{{ end }}"
    ]
  },
  "console_title_template": "{{if .Root}}(Admin){{end}} {{.PWD}}",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "template": "{{ .UserName }} ",
          "foreground": "#bb9af7",
          "type": "session",
          "style": "plain"
        },
        {
          "options": {
            "style": "full"
          },
          "template": "{{ .Path }} ",
          "foreground": "#7dcfff",
          "type": "path",
          "style": "plain"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "options": {
            "branch_ahead_icon": "<#89ddff>\u21e1 </>",
            "branch_behind_icon": "<#89ddff>\u21e3 </>",
            "branch_icon": "",
            "fetch_status": true,
            "fetch_upstream_icon": true,
            "github_icon": ""
          },
          "template": "{{ .UpstreamIcon }}{{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }}<#ffafd7>*</>{{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }} \ueb4b {{ .StashCount }}{{ end }} ",
          "foreground": "#a9b1d6",
          "type": "git",
          "style": "plain"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "options": {
            "style": "austin"
          },
          "template": " {{ .FormattedMs }} ",
          "foreground": "#9ece6a",
          "type": "executiontime",
          "style": "plain"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "options": {
            "always_enabled": true
          },
          "template": "❯ ",
          "foreground": "#c0caf5",
          "type": "status",
          "style": "plain",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#f7768e{{ end }}"
          ]
        }
      ],
      "newline": true
    }
  ],
  "version": 4
}
